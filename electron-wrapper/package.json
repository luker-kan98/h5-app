{
  "name": "h5-electron-wrapper",
  "version": "1.0.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac dir --x64 --publish never",
    "build:win": "electron-builder --win --x64 --publish never"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.h5packager.app",
    "productName": "H5 App",
    "mac": {
      "target": "dir"
    },
    "win": {
      "target": "nsis"
    }
  }
}
