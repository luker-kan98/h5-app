{
  "name": "h5-electron-wrapper",
  "version": "1.0.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "build:mac": "electron-builder --mac --publish never",
    "build:win": "electron-builder --win nsis --publish never",
    "test": "vitest run"
  },
  "dependencies": {
    "socks-proxy-agent": "^8.0.4",
    "@sentry/electron": "^5.4.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0",
    "vitest": "^1.6.0",
    "sinon": "^17.0.0"
  },
  "build": {
    "appId": "com.h5packager.app",
    "productName": "H5 App",
    "extraResources": [
      { "from": "resources/singbox", "to": "singbox", "filter": ["**/*"] }
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
  }
}
