# Copy this file to backend/.env.production and replace every placeholder before
# reloading backend/celery/scheduler launchd services.

SECRET_KEY=replace-with-random-secret
DATABASE_URL=postgresql+psycopg://h5app:replace-this-password@127.0.0.1:5432/h5app
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
BUILDS_DIR=/Users/ec2-user/h5-app/builds
REPO_ROOT=/Users/ec2-user/h5-app
JAVA_HOME=/opt/homebrew/opt/openjdk@17/libexec/openjdk.jdk/Contents/Home
ANDROID_HOME=/opt/homebrew/share/android-commandlinetools
SCHEDULER_INTERVAL_SECONDS=2
